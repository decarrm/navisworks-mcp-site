---
interface Spec {
  label: string;
  value: string;
}
interface Props {
  part: string;
  name: string;
  price: string;
  priceUnit?: string;
  tagline: string;
  specs: Spec[];
  cta: { label: string; href?: string; tier?: "STUDIO" | "ENTERPRISE" };
  featured?: boolean;
}
const { part, name, price, priceUnit = "", tagline, specs, cta, featured = false } = Astro.props;
---

<article class={`pmrow${featured ? ' pmrow--featured' : ''}`}>
  <div class="pmrow__lead">
    <span class="mono-caps pmrow__part">[{part}]</span>
    <span class="pmrow__name">{name}</span>
    <span class="mono-caps pmrow__tagline">{tagline}</span>
  </div>

  <dl class="pmrow__specs">
    {specs.map((s) => (
      <div class="pmrow__spec">
        <dt class="mono-caps">{s.label}</dt>
        <dd class="num-read">{s.value}</dd>
      </div>
    ))}
  </dl>

  <div class="pmrow__price">
    <span class="pmrow__amount num-read">{price}</span>
    {priceUnit && <span class="mono-caps pmrow__unit">{priceUnit}</span>}
  </div>

  <div class="pmrow__cta">
    {cta.tier ? (
      <form method="POST" action="/api/checkout" data-checkout>
        <input type="hidden" name="tier" value={cta.tier} />
        <button type="submit" class={`btn ${featured ? 'btn--safety' : ''}`}>{cta.label}</button>
      </form>
    ) : (
      <a class="btn btn--ghost" href={cta.href}>{cta.label}</a>
    )}
  </div>
</article>

<style>
  .pmrow {
    display: grid;
    grid-template-columns: 1.6fr 2.2fr 0.9fr 0.9fr;
    gap: 24px;
    align-items: start;
    padding: 28px 0;
    border-top: 1px solid var(--color-ink);
    position: relative;
  }
  .pmrow:last-of-type { border-bottom: 1px solid var(--color-ink); }
  .pmrow--featured::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--color-paper-shade);
    z-index: -1;
  }
  .pmrow--featured::after {
    content: "★ RECOMMENDED";
    position: absolute;
    top: -9px;
    left: 24px;
    background: var(--color-safety);
    color: var(--color-paper);
    padding: 2px 10px;
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.2em;
  }

  .pmrow__lead { display: grid; gap: 6px; padding-left: 16px; }
  .pmrow__part { color: var(--color-safety); font-size: 11px; }
  .pmrow__name {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    line-height: 1;
  }
  .pmrow__tagline { color: var(--color-ink-soft); max-width: 24ch; letter-spacing: 0.06em; }

  .pmrow__specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px 20px;
    margin: 0;
  }
  .pmrow__spec {
    display: grid;
    gap: 2px;
    padding-bottom: 8px;
    border-bottom: 1px dashed var(--color-rule);
  }
  .pmrow__spec dt { color: var(--color-ink-soft); font-size: 10px; }
  .pmrow__spec dd { margin: 0; font-size: 13px; color: var(--color-ink); }

  .pmrow__price {
    display: grid;
    justify-items: end;
    align-items: baseline;
    padding-right: 8px;
  }
  .pmrow__amount {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    line-height: 1;
    color: var(--color-ink);
  }
  .pmrow__unit { color: var(--color-ink-soft); margin-top: 4px; }

  .pmrow__cta {
    display: flex;
    justify-content: flex-end;
    padding-right: 16px;
  }
  .pmrow__cta .btn { width: 100%; justify-content: space-between; }

  @media (max-width: 900px) {
    .pmrow { grid-template-columns: 1fr 1fr; }
    .pmrow__lead { grid-column: 1 / 3; padding-left: 0; }
    .pmrow__cta { padding-right: 0; }
  }
</style>
