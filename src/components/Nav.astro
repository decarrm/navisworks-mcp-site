---
const links = [
  { label: "Overview", href: "/#overview", ref: "§01" },
  { label: "Integration", href: "/#integration", ref: "§03" },
  { label: "Pricing", href: "/pricing", ref: "/02" },
  { label: "Docs", href: "/docs", ref: "/03" },
];
const pathname = Astro.url.pathname;
---

<nav class="nav" aria-label="Primary">
  <div class="sheet nav__inner">
    <a href="/" class="nav__brand" aria-label="Navisworks MCP Toolkit — home">
      <svg class="nav__mark" viewBox="0 0 48 48" width="36" height="36" aria-hidden="true">
        <rect x="1" y="1" width="46" height="46" fill="none" stroke="currentColor" stroke-width="1.5" />
        <path d="M8 40 L8 8 L40 40 L40 8" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="miter" />
        <circle cx="8" cy="8" r="2.2" fill="currentColor" />
        <circle cx="40" cy="40" r="2.2" fill="currentColor" />
      </svg>
      <span class="nav__wordmark">
        <span class="nav__word-lead">NAVISWORKS</span>
        <span class="nav__word-sub">MCP · TOOLKIT</span>
      </span>
    </a>

    <ul class="nav__links">
      {links.map((l) => {
        const active = l.href === pathname || (l.href.startsWith('/') && l.href !== '/' && pathname.startsWith(l.href));
        return (
          <li>
            <a href={l.href} class={`nav__link${active ? ' is-active' : ''}`}>
              <span class="nav__link-ref mono-caps">{l.ref}</span>
              <span class="nav__link-label">{l.label}</span>
            </a>
          </li>
        );
      })}
    </ul>

    <a class="btn btn--ghost nav__cta" href="https://github.com/decarrm/navisworks-mcp-toolkit">GitHub</a>
  </div>
  <div class="nav__underrule" aria-hidden="true"></div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in oklab, var(--color-paper) 88%, transparent);
    backdrop-filter: blur(6px);
  }
  .nav__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 32px;
    padding-block: 14px;
  }
  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--color-ink);
  }
  .nav__mark { color: var(--color-blueprint); }
  .nav__wordmark { display: grid; line-height: 1; }
  .nav__word-lead {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.18em;
    font-weight: 600;
  }
  .nav__word-sub {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.28em;
    color: var(--color-ink-soft);
    margin-top: 4px;
  }

  .nav__links {
    display: flex;
    justify-content: center;
    gap: 28px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nav__link {
    display: inline-grid;
    grid-auto-flow: column;
    align-items: baseline;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink);
    padding-bottom: 6px;
    border-bottom: 1px solid transparent;
    transition: border-color 140ms ease;
  }
  .nav__link-ref { color: var(--color-safety); font-size: 10px; }
  .nav__link:hover { border-bottom-color: var(--color-ink); }
  .nav__link.is-active { border-bottom-color: var(--color-safety); }

  .nav__cta { padding: 10px 16px 9px; font-size: 11.5px; }

  .nav__underrule {
    height: 1px;
    background-image: linear-gradient(90deg, var(--color-ink) 50%, transparent 0);
    background-size: 5px 1px;
    opacity: 0.3;
  }

  @media (max-width: 860px) {
    .nav__links { display: none; }
    .nav__inner { grid-template-columns: auto 1fr auto; gap: 16px; }
  }
</style>
