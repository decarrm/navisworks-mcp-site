---
interface Props {
  num: string;
  title: string;
  body: string;
  meta?: string;
  icon?: "query" | "mcp" | "navis" | "python" | "tests" | "billing";
}
const { num, title, body, meta, icon } = Astro.props;
---

<article class="tcard">
  <header class="tcard__head">
    <span class="mono-caps tcard__num">{num}</span>
    {meta && <span class="mono-caps tcard__meta">{meta}</span>}
  </header>

  {icon && (
    <div class="tcard__icon" aria-hidden="true">
      {icon === "query" && (
        <svg viewBox="0 0 64 64" width="100%" height="100%">
          <rect x="6" y="14" width="44" height="30" fill="none" stroke="currentColor" stroke-width="1.5" />
          <path d="M14 24 L42 24 M14 32 L36 32 M14 40 L28 40" stroke="currentColor" stroke-width="1.5" />
          <path d="M44 42 L56 54" stroke="currentColor" stroke-width="2" />
          <circle cx="42" cy="40" r="7" fill="none" stroke="currentColor" stroke-width="1.5" />
        </svg>
      )}
      {icon === "mcp" && (
        <svg viewBox="0 0 64 64" width="100%" height="100%">
          <circle cx="32" cy="32" r="22" fill="none" stroke="currentColor" stroke-width="1.5" />
          <path d="M18 32 L46 32 M32 18 L32 46" stroke="currentColor" stroke-width="1.5" />
          <circle cx="18" cy="32" r="3" fill="currentColor" />
          <circle cx="46" cy="32" r="3" fill="currentColor" />
          <circle cx="32" cy="18" r="3" fill="currentColor" />
          <circle cx="32" cy="46" r="3" fill="currentColor" />
        </svg>
      )}
      {icon === "navis" && (
        <svg viewBox="0 0 64 64" width="100%" height="100%">
          <path d="M10 52 L10 14 L32 42 L32 14 L54 42 L54 14" fill="none" stroke="currentColor" stroke-width="2" />
          <circle cx="10" cy="14" r="2.5" fill="currentColor" />
          <circle cx="54" cy="42" r="2.5" fill="currentColor" />
        </svg>
      )}
      {icon === "python" && (
        <svg viewBox="0 0 64 64" width="100%" height="100%">
          <rect x="10" y="18" width="44" height="28" fill="none" stroke="currentColor" stroke-width="1.5" />
          <path d="M16 26 L22 32 L16 38" fill="none" stroke="currentColor" stroke-width="1.5" />
          <path d="M28 40 L40 40" stroke="currentColor" stroke-width="1.5" />
        </svg>
      )}
      {icon === "tests" && (
        <svg viewBox="0 0 64 64" width="100%" height="100%">
          <rect x="8" y="10" width="48" height="44" fill="none" stroke="currentColor" stroke-width="1.5" />
          <path d="M14 22 L18 26 L28 16" fill="none" stroke="currentColor" stroke-width="2" />
          <path d="M14 36 L18 40 L28 30" fill="none" stroke="currentColor" stroke-width="2" />
          <path d="M14 48 L28 48 M34 22 L50 22 M34 36 L50 36 M34 48 L50 48" stroke="currentColor" stroke-width="1.5" />
        </svg>
      )}
      {icon === "billing" && (
        <svg viewBox="0 0 64 64" width="100%" height="100%">
          <rect x="8" y="16" width="48" height="32" fill="none" stroke="currentColor" stroke-width="1.5" />
          <path d="M8 26 L56 26" stroke="currentColor" stroke-width="1.5" />
          <circle cx="16" cy="38" r="2" fill="currentColor" />
          <path d="M24 38 L48 38" stroke="currentColor" stroke-width="1.5" />
        </svg>
      )}
    </div>
  )}

  <h3 class="tcard__title">{title}</h3>
  <p class="tcard__body">{body}</p>
</article>

<style>
  .tcard {
    position: relative;
    background: var(--color-paper);
    border: 1.5px solid var(--color-ink);
    padding: 20px 22px 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 180ms ease, color 180ms ease, transform 180ms ease;
  }
  .tcard::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 6px;
    background-image: linear-gradient(90deg, var(--color-ink) 50%, transparent 0);
    background-size: 4px 1px;
    background-repeat: repeat-x;
    background-position: 0 6px;
    opacity: 0.5;
  }
  .tcard__head {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    color: var(--color-ink-soft);
  }
  .tcard__num { color: var(--color-safety); }
  .tcard__icon {
    color: var(--color-blueprint);
    width: 48px;
    height: 48px;
    margin-top: 4px;
  }
  .tcard__title {
    font-size: 1.45rem;
    line-height: 1.05;
    max-width: 18ch;
    color: var(--color-ink);
  }
  .tcard__body {
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.65;
    color: var(--color-ink-soft);
    margin: 0;
  }
  .tcard:hover {
    background: var(--color-ink);
    color: var(--color-paper);
  }
  .tcard:hover .tcard__title { color: var(--color-paper); }
  .tcard:hover .tcard__body { color: color-mix(in oklab, var(--color-paper) 80%, transparent); }
  .tcard:hover .tcard__icon { color: var(--color-safety); }
  .tcard:hover .tcard__num { color: var(--color-safety); }
  .tcard:hover::before { opacity: 0.8; background-image: linear-gradient(90deg, var(--color-paper) 50%, transparent 0); }
</style>
