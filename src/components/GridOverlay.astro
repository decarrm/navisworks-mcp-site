---
// Pure presentational — the faint 8px drafting grid is applied on <body>
// via global.css. This component adds the page-level crosshair markers
// along the left/right edges, anchoring the whole page into a drawing.
---

<div class="overlay" aria-hidden="true">
  <span class="overlay__origin">
    <span class="mono-caps">0,0</span>
  </span>
  <span class="overlay__north">
    <svg width="28" height="40" viewBox="0 0 28 40">
      <path d="M14 2 L22 28 L14 22 L6 28 Z" fill="var(--color-ink)" />
      <text x="14" y="38" text-anchor="middle" font-family="IBM Plex Mono, monospace" font-size="10" fill="var(--color-ink)">N</text>
    </svg>
  </span>
</div>

<style>
  .overlay {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }
  .overlay__origin {
    position: absolute;
    left: 14px;
    bottom: 14px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--color-ink-soft);
  }
  .overlay__origin::before {
    content: "";
    width: 18px;
    height: 18px;
    background:
      linear-gradient(var(--color-ink), var(--color-ink)) 50% 0 / 1.5px 100% no-repeat,
      linear-gradient(var(--color-ink), var(--color-ink)) 0 50% / 100% 1.5px no-repeat;
    border: 1px solid var(--color-ink);
    border-radius: 50%;
  }
  .overlay__north {
    position: absolute;
    right: 22px;
    top: 96px;
    opacity: 0.7;
  }
  @media (max-width: 860px) {
    .overlay__north { display: none; }
  }
</style>
