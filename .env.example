# Public site URL, used for Stripe success/cancel redirects
PUBLIC_SITE_URL=https://navisworks-mcp-site.pages.dev

# Stripe — leave unset during development. The /api/checkout endpoint will
# return a clear 503 "stripe_not_configured" response until these are set.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_STUDIO=
STRIPE_PRICE_ID_ENTERPRISE=
